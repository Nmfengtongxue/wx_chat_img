{
  "name": "wx-chat-img",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && VITE_BASE=/wx_chat_img/ vite build",
    "build:gitee-pages": "tsc -b && VITE_BASE=/Wx_chat_images/ vite build",
    "deploy:cloudbase": "npm run build && tcb hosting deploy dist -e wx-chat-images-d5g75hzivc47793bd",
    "deploy:cloudbase:only": "tcb hosting deploy dist -e wx-chat-images-d5g75hzivc47793bd",
    "lint": "oxlint",
    "preview": "vite preview",
    "generate:presets": "python3 scripts/generate_burst_presets.py",
    "cutout:avatars": "python3 scripts/cutout_avatar.py",
    "assets:avatars": "npm run generate:presets && npm run cutout:avatars"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudbase/cli": "^3.5.9",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
